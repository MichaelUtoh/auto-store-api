# Server
PORT=8089
GIN_MODE=release

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=auto_store
DB_SSLMODE=disable

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_SECRET=your-super-secret-key-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# Rate Limiting
RATE_LIMIT_RPM=60
AUTH_RATE_LIMIT_RPM=10
ACCOUNT_LOCKOUT_ATTEMPTS=5
ACCOUNT_LOCKOUT_DURATION=15m

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:8089

# App (Next.js frontend — used in notification email deep links)
APP_FRONTEND_URL=http://localhost:3000

# Notifications (Redis queue + worker)
NOTIFICATIONS_WORKER_ENABLED=true
NOTIFICATIONS_MAX_RETRIES=5
NOTIFICATIONS_DEQUEUE_TIMEOUT_SEC=5

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@auto-store.com

# File Upload
UPLOAD_MAX_SIZE=5242880
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/webp

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# S3 (optional - for product images)
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
# Where the API sends PutObject (use http://localhost:9000 when running `go run` on the host)
# When the API runs in Docker and MinIO is on the host, use host.docker.internal instead of localhost:
# S3_ENDPOINT=http://host.docker.internal:9000
S3_ENDPOINT=
# Optional. Base URL stored/returned for browsers (omit when Endpoint is already reachable from clients).
# With Docker + host MinIO, set this to your public MinIO URL, e.g. http://localhost:9000/your-bucket-name
S3_PUBLIC_URL=
# PutObject never sends ACLs (AWS Object Ownership / ACLs disabled). Use bucket policy or CloudFront for reads.

# Paystack (planned — installation marketplace + order payments)
# PAYSTACK_SECRET_KEY=
# PAYSTACK_PUBLIC_KEY=
# PAYSTACK_WEBHOOK_SECRET=
# PAYSTACK_CALLBACK_URL=http://localhost:3000/checkout/verify
