{
	"info": {
		"name": "Auto-Store API",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
		"description": "Auto-parts e-commerce API - import into Postman for testing"
	},
	"variable": [
		{ "key": "baseUrl", "value": "http://localhost:8080/api/v1" },
		{ "key": "accessToken", "value": "" }
	],
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Register",
					"request": {
						"method": "POST",
						"url": "{{baseUrl}}/auth/register",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\",\n  \"first_name\": \"John\",\n  \"last_name\": \"Doe\"\n}"
						}
					}
				},
				{
					"name": "Login",
					"request": {
						"method": "POST",
						"url": "{{baseUrl}}/auth/login",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\"\n}"
						}
					}
				},
				{
					"name": "Refresh",
					"request": {
						"method": "POST",
						"url": "{{baseUrl}}/auth/refresh",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"refresh_token\": \"{{accessToken}}\"\n}"
						}
					}
				}
			]
		},
		{
			"name": "Products",
			"item": [
				{
					"name": "List Products",
					"request": {
						"method": "GET",
						"url": "{{baseUrl}}/products?page=1&limit=20"
					}
				},
				{
					"name": "Search Products",
					"request": {
						"method": "GET",
						"url": "{{baseUrl}}/products/search?q=brake&minPrice=10&maxPrice=500&page=1&limit=20"
					}
				},
				{
					"name": "Get Product",
					"request": {
						"method": "GET",
						"url": "{{baseUrl}}/products/:id"
					}
				}
			]
		},
		{
			"name": "Categories",
			"item": [
				{
					"name": "List Categories (tree)",
					"request": {
						"method": "GET",
						"url": "{{baseUrl}}/categories"
					}
				}
			]
		},
		{
			"name": "Health",
			"request": {
				"method": "GET",
				"url": "http://localhost:8080/health"
			}
		}
	]
}
